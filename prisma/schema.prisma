generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Channel {
  id                   String              @id @default(cuid())
  name                 String              @default("Untitled Channel")
  language             String              @default("en")
  niche                String?
  status               ChannelStatus       @default(DRAFT)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  exploreTopic         String?
  nicheMode            NicheSelectionMode  @default(DISCOVER)
  contentIntent        String?
  contentStrategy      Json?
  instagramAccessToken String?
  instagramTokenExpiry DateTime?
  instagramUserId      String?
  instagramUsername    String?
  carouselLayout       CarouselLayout      @default(BOLD)
  batchOrders          BatchOrder[]
  carouselJobs         CarouselJob[]
  memory               ChannelMemory?
  positioning          ChannelPositioning?
  visualStyle          ChannelVisualStyle?
  generationJobs       GenerationJob[]
  nicheOptions         NicheOption[]
  posts                Post[]
}

model ChannelVisualStyle {
  id                 String   @id @default(cuid())
  channelId          String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  headlineColor      String?
  emphasisColor      String?
  bodyColor          String?
  textBgEnabled      Boolean  @default(false)
  textBgColor        String?
  logoBase64         String?
  logoPosition       String   @default("bottom_right")
  logoSizePx         Int      @default(80)
  titleFontId        String   @default("inter")
  bodyFontId         String   @default("lora")
  singleFont         Boolean  @default(false)
  t1FontSizePx       Int      @default(72)
  t2FontSizePx       Int      @default(36)
  bodyAlign          String   @default("left")
  bodyWeight         Int      @default(400)
  titleAlign         String   @default("left")
  titleWeight        Int      @default(800)
  t1FontSizePxCta    Int?
  t1FontSizePxOpener Int?
  channel            Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model ChannelPositioning {
  id           String   @id @default(cuid())
  channelId    String   @unique
  angle        String
  tone         String
  contentStyle String
  audienceFeel String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  channel      Channel  @relation(fields: [channelId], references: [id])
}

model ChannelMemory {
  id              String   @id @default(cuid())
  channelId       String   @unique
  tone            String
  aggressionLevel Float
  style           String
  avoidPatterns   Json
  preferredHooks  Json
  forbiddenWords  Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  channel         Channel  @relation(fields: [channelId], references: [id])
}

model NicheOption {
  id                String   @id @default(cuid())
  channelId         String
  title             String
  description       String
  competitionScore  Int
  viralityScore     Int
  contentEaseScore  Int
  monetizationScore Int
  rationale         String
  selected          Boolean  @default(false)
  createdAt         DateTime @default(now())
  contentIntent     String?
  channel           Channel  @relation(fields: [channelId], references: [id])

  @@index([channelId])
}

model Post {
  id            String       @id @default(cuid())
  channelId     String
  dayIndex      Int
  title         String
  hook          String
  type          PostType
  status        PostStatus   @default(DRAFT)
  publishDate   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  visualHint    String?
  pattern       PostPattern?
  carouselJobId String?      @unique
  caption       Caption?
  carouselJob   CarouselJob? @relation(fields: [carouselJobId], references: [id])
  channel       Channel      @relation(fields: [channelId], references: [id])
  slides        Slide[]

  @@unique([channelId, dayIndex])
  @@index([channelId])
}

model Slide {
  id                String    @id @default(cuid())
  postId            String
  slideIndex        Int
  role              SlideRole
  text              String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  body              String?
  concretenessScore Int       @default(3)
  containsNumber    Boolean   @default(false)
  factType          String?
  headline          String?
  noveltyScore      Int       @default(3)
  qualityPassed     Boolean   @default(true)
  supportingDetail  String?
  topicEntity       String?
  displayTitle      String?
  displaySupport    String?
  post              Post      @relation(fields: [postId], references: [id])

  @@unique([postId, slideIndex])
}

model Caption {
  id        String   @id @default(cuid())
  postId    String   @unique
  text      String
  hashtags  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id])
}

model CarouselJob {
  id                   String            @id @default(cuid())
  topic                String
  direction            String?
  status               CarouselJobStatus @default(PENDING)
  approved             Boolean           @default(false)
  progress             Json?
  errorMessage         String?
  pipelineMeta         Json?
  caption              String?
  hashtags             String[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  channelId            String?
  batchOrderId         String?
  article              String?
  exactSubject         String?
  instagramMediaId     String?
  instagramPublishedAt DateTime?
  publishedToInstagram Boolean           @default(false)
  layout               CarouselLayout    @default(BOLD)
  batchOrder           BatchOrder?       @relation(fields: [batchOrderId], references: [id])
  channel              Channel?          @relation(fields: [channelId], references: [id])
  slides               CarouselSlide[]
  post                 Post?

  @@index([channelId])
  @@index([batchOrderId])
}

model CarouselSlide {
  id                  String              @id @default(cuid())
  carouselJobId       String
  slideIndex          Int
  role                SlideRole
  headline            String?
  body                String?
  supportingDetail    String?
  factType            String?
  containsNumber      Boolean             @default(false)
  concretenessScore   Int                 @default(3)
  noveltyScore        Int                 @default(3)
  topicEntity         String?
  displayTitle        String?
  displaySupport      String?
  imageUrl            String?
  imageError          String?
  status              CarouselSlideStatus @default(PENDING)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  imageSource         String?             @default("generated")
  imageSourceUrl      String?
  imageAuthor         String?
  imagePromptOverride String?
  wikipediaQuery      String?
  hasEmbeddedText     Boolean             @default(true)
  carouselJob         CarouselJob         @relation(fields: [carouselJobId], references: [id], onDelete: Cascade)

  @@unique([carouselJobId, slideIndex])
  @@index([carouselJobId])
}

model BatchOrder {
  id           String           @id @default(cuid())
  channelId    String
  status       BatchOrderStatus @default(PENDING)
  size         Int
  topics       Json?
  direction    String?
  completed    Int              @default(0)
  failed       Int              @default(0)
  progress     Json?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  channel      Channel          @relation(fields: [channelId], references: [id])
  carouselJobs CarouselJob[]

  @@index([channelId])
}

model GenerationJob {
  id           String    @id @default(cuid())
  channelId    String
  postId       String?
  jobType      JobType
  status       JobStatus @default(PENDING)
  payload      Json?
  result       Json?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  channel      Channel   @relation(fields: [channelId], references: [id])

  @@index([channelId, jobType])
}

enum ChannelStatus {
  DRAFT
  NICHE_SELECTED
  POSITIONED
  HOOKS_GENERATED
  CONTENT_GENERATED
  COMPLETE
  NAMED
  STRATEGY_DEFINED
}

enum PostStatus {
  DRAFT
  GENERATED
  REVIEWED
  APPROVED
}

enum PostType {
  CONTRARIAN
  CALL_OUT
  MISTAKE_EXPOSURE
  HIDDEN_TRUTH
}

enum PostPattern {
  CONTRAST
  MISTAKE
  MYTH
  LIST
  STORY
  BREAKDOWN
  OPINION
  SCALE
  TIMELINE
  VERSUS
  MECHANISM
  MISCONCEPTION
  EXTREMES
}

enum SlideRole {
  HOOK
  SETUP
  BUILD
  TWIST
  INSIGHT
  CTA
  OPENER
  FACT
  IMPLICATION
}

enum JobType {
  NICHE_GENERATION
  POSITIONING
  HOOK_GENERATION
  POST_GENERATION
  CAPTION_GENERATION
  REGENERATION
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CarouselJobStatus {
  PENDING
  GENERATING
  RENDERING
  COMPLETE
  FAILED
}

enum CarouselSlideStatus {
  PENDING
  FAILED_IMAGE
  REGENERATING
  APPROVED
}

enum NicheSelectionMode {
  DISCOVER
  EXPLORE
  DIRECT
}

enum CarouselLayout {
  DETAILED
  BOLD
}

enum BatchOrderStatus {
  PENDING
  GENERATING_HOOKS
  RUNNING
  COMPLETE
  FAILED
}
